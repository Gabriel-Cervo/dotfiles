# ~/.zshrc — sources the dotfiles repo
#
# Escape hatch: to roll back to Oh My Zsh, comment out the source lines below
# and uncomment the two lines for OMZ.
#
# export ZSH="$HOME/.oh-my-zsh"
# source $ZSH/oh-my-zsh.sh

# Source all config files in order
source "$HOME/.config/zsh/env.zsh"
source "$HOME/.config/zsh/options.zsh"
source "$HOME/.config/zsh/history.zsh"
source "$HOME/.config/zsh/completions.zsh"
source "$HOME/.config/zsh/prompt.zsh"
source "$HOME/.config/zsh/plugins.zsh"
source "$HOME/.config/zsh/tools/rbenv.zsh"
source "$HOME/.config/zsh/tools/fnm.zsh"

# p10k integration lives in prompt.zsh. If you ever re-run `p10k configure`
# and the wizard offers to modify ~/.zshrc, **decline** — your p10k config is
# already wired up through prompt.zsh, and accepting would duplicate the
# instant-prompt block. To restore this clean file at any time:
#   git -C ~/dotfiles checkout zsh/zshrc
