# plugins.zsh — managerless plugin loading
# Both plugins are cloned to ~/.zsh/plugins/ and sourced directly.

# zsh-autosuggestions (fish-like ghost text suggestions)
source "$HOME/.zsh/plugins/zsh-autosuggestions/zsh-autosuggestions.zsh"

# fast-syntax-highlighting (colors commands as you type)
source "$HOME/.zsh/plugins/fast-syntax-highlighting/fast-syntax-highlighting.plugin.zsh"
